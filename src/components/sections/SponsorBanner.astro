---
// Banner publicitario (patrocinador). Imagen oficial extraída del Figma.
---

<section class="px-5 pb-16 sm:px-8">
  <a
    href="https://www.caliente.mx"
    target="_blank"
    rel="noopener nofollow sponsored"
    class="block max-w-[1136px] mx-auto"
    aria-label="Caliente.mx — 20 millones de pesos en cada partido. Apuesta aquí."
  >
    <img
      src="/img/caliente-banner.webp"
      alt="Caliente.mx — 20 millones de pesos en cada partido"
      width="1150"
      height="161"
      class="h-auto w-full rounded-xl shadow-lg"
      loading="lazy"
      decoding="async"
    />
  </a>
</section>
