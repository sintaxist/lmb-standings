---
interface Props {
  kicker: string;
  title: string;
  /** Línea roja que se extiende a la derecha del título (estilo Figma). */
  rule?: boolean;
}

const { kicker, title, rule = true } = Astro.props;
---

<div class="flex flex-col gap-1.5">
  <p class="section-kicker tracking-widest">{kicker}</p>
  <div class="flex items-center gap-4">
    <h2 class="section-title tracking-wider">{title}</h2>
    <slot />
    {rule && (
      <span
        class="h-px flex-1 bg-gradient-to-r from-brand-red to-transparent"
        aria-hidden="true"
      ></span>
    )}
  </div>
</div>
