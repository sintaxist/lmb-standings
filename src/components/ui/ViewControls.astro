---
// Barra de controles: filtra por división, busca por nombre, ordena y alterna
// entre vista de tarjetas y tabla. Solo markup + estado inicial; la conducta
// vive en el controlador (src/scripts/standings-controller.ts).

const TABS = [
  { value: "all", label: "Todas" },
  { value: "norte", label: "Norte" },
  { value: "sur", label: "Sur" },
] as const;

const SORTS = [
  { value: "rank", label: "Posición" },
  { value: "pct", label: "% Victorias" },
  { value: "wins", label: "Victorias" },
  { value: "losses", label: "Derrotas" },
  { value: "gb", label: "Juegos atrás" },
  { value: "streak", label: "Racha" },
  { value: "rundiff", label: "Diferencial" },
] as const;
---

<div data-standings-controls class="shell flex flex-col gap-5 py-6">
  <!-- Fila 1: tabs de división + toggle de vista -->
  <div class="flex flex-wrap items-center justify-between gap-4 border-b border-line">
    <div class="flex gap-6" role="tablist" aria-label="Filtrar por división">
      {TABS.map((tab, i) => (
        <button
          type="button"
          role="tab"
          class="division-tab relative -mb-px border-b-2 border-transparent pb-3 font-sans text-sm font-bold uppercase tracking-wide text-muted transition-colors data-[active]:border-brand-red data-[active]:text-ink"
          data-division={tab.value}
          data-active={i === 0 ? "" : null}
          aria-selected={i === 0 ? "true" : "false"}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="mb-2 inline-flex rounded-lg border border-line bg-surface p-1">
      {[
        {
          value: "cards",
          label: "Tarjetas",
          icon: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
        },
        {
          value: "table",
          label: "Tabla",
          icon: '<rect x="3" y="4" width="18" height="16" rx="1.5"/><path d="M3 9h18M3 14.5h18M9 4v16"/>',
        },
      ].map((view, i) => (
        <button
          type="button"
          class="view-toggle flex items-center gap-1.5 rounded-md px-3 py-1.5 font-sans text-xs font-semibold uppercase tracking-wide text-muted transition-colors data-[active]:bg-ink data-[active]:text-white"
          data-view={view.value}
          data-active={i === 0 ? "" : null}
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={view.icon} />
          {view.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Fila 2: búsqueda + orden -->
  <div class="flex flex-wrap items-center gap-3">
    <label class="relative min-w-[220px] flex-1">
      <span class="sr-only">Buscar equipo</span>
      <svg
        class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-muted"
        width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
      </svg>
      <input
        id="team-search"
        type="search"
        placeholder="Buscar equipo..."
        autocomplete="off"
        class="w-full rounded-lg border border-line bg-surface py-2.5 pl-10 pr-3 font-sans text-sm text-ink outline-none transition-colors placeholder:text-muted focus:border-brand-navy"
      />
    </label>

    <label class="flex items-center gap-2">
      <span class="sr-only">Ordenar por</span>
      <div class="relative">
        <select
          id="sort-field"
          class="appearance-none rounded-lg border border-line bg-surface py-2.5 pl-3 pr-9 font-sans text-sm font-medium text-ink outline-none transition-colors focus:border-brand-navy"
        >
          {SORTS.map((s) => <option value={s.value}>{s.label}</option>)}
        </select>
        <svg
          class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted"
          width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </div>
    </label>

    <button
      id="sort-dir"
      type="button"
      class="flex h-[42px] w-[42px] items-center justify-center rounded-lg border border-line bg-surface text-muted transition-colors hover:border-brand-navy"
      aria-label="Invertir orden"
    >
      <svg
        id="sort-dir-icon"
        width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
      >
        <path d="M8 13V3" /><path d="M4 7l4-4 4 4" />
      </svg>
    </button>
  </div>

  <p id="filter-summary" class="hidden font-sans text-xs text-muted">
    Mostrando <span id="filter-count" class="font-semibold text-ink">0</span> equipos
  </p>
</div>
