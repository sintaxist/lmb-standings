---
import type { Streak } from "@/lib/mlb";

interface Props {
  streak: Streak;
  /** Compacta para usar dentro de la tabla. */
  size?: "md" | "sm";
}

const { streak, size = "md" } = Astro.props;
const pad = size === "sm" ? "px-2 py-0.5 text-[11px]" : "px-3 py-1 text-xs";
---

<span
  class:list={[
    "inline-flex items-center gap-1 rounded-full font-sans font-bold tabular",
    pad,
    streak.isWin
      ? "bg-positive-soft text-positive ring-1 ring-positive/25"
      : "bg-negative-soft text-negative ring-1 ring-negative/20",
  ]}
  aria-label={streak.isWin
    ? `Racha de ${streak.length} victorias`
    : `Racha de ${streak.length} derrotas`}
>
  <span aria-hidden="true">{streak.isWin ? "▲" : "▼"}</span>
  {streak.code}
</span>
