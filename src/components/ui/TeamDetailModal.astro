---
import type { TeamDetailMap } from "@/lib/mlb";

interface Props {
  details: TeamDetailMap;
}

const { details } = Astro.props;

// Grupos de stats: cada fila es etiqueta + id del valor + tooltip opcional.
type Row = { id: string; label: string; tip?: string };

const POSITION: Row[] = [
  { id: "tm-div-rank", label: "En su división", tip: "Lugar que ocupa dentro de su división" },
  { id: "tm-league-rank", label: "En la liga", tip: "Lugar que ocupa entre todos los equipos de la liga" },
  { id: "tm-gb", label: "Juegos detrás del líder", tip: "Cuántos juegos lo separan del primer lugar de su división" },
  { id: "tm-div-record", label: "Récord en su división", tip: "Ganados-perdidos jugando solo contra equipos de su división" },
];

const RUNS: Row[] = [
  { id: "tm-rs", label: "Carreras anotadas", tip: "Total de carreras a favor en la temporada" },
  { id: "tm-ra", label: "Carreras permitidas", tip: "Total de carreras en contra en la temporada" },
  { id: "tm-dif", label: "Diferencia de carreras", tip: "Carreras anotadas menos las permitidas" },
  { id: "tm-rpg-for", label: "Anota por juego", tip: "Promedio de carreras a favor por partido" },
  { id: "tm-rpg-against", label: "Permite por juego", tip: "Promedio de carreras en contra por partido" },
];

const PROJECTION: Row[] = [
  { id: "tm-expected", label: "Récord esperado", tip: "El récord que “debería” tener según sus carreras a favor y en contra" },
  { id: "tm-magic", label: "Número mágico", tip: "Victorias propias (o derrotas del rival) que le faltan para asegurar su división" },
];

const GROUPS: Array<{ title: string; rows: Row[] }> = [
  { title: "Posición", rows: POSITION },
  { title: "Carreras", rows: RUNS },
  { title: "Proyección", rows: PROJECTION },
];

const labelClass =
  "cursor-help underline decoration-dotted decoration-muted/40 underline-offset-4 outline-none focus-visible:decoration-ink";
---

<!-- Detalle por equipo, consumido por el controlador del modal en cliente -->
<script id="team-details" type="application/json" set:html={JSON.stringify(details)}></script>

<dialog
  id="team-modal"
  class="m-auto max-h-[90vh] w-[min(94vw,540px)] overflow-hidden rounded-2xl border border-line bg-surface p-0 shadow-2xl backdrop:bg-black/55 backdrop:backdrop-blur-sm"
  aria-labelledby="tm-name"
>
  <!-- Cabecera oscura -->
  <header class="relative flex items-center gap-4 bg-ink px-6 pb-5 pt-6">
    <button
      id="tm-close"
      type="button"
      class="absolute right-4 top-4 flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-white/80 transition-colors hover:bg-white/20"
      aria-label="Cerrar"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <span id="tm-logo" class="inline-flex h-16 w-16 flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-white ring-2 ring-white/15"></span>

    <div class="min-w-0">
      <p id="tm-sub" class="font-sans text-xs font-semibold uppercase tracking-[0.16em] text-white/55"></p>
      <h2 id="tm-name" class="truncate font-display text-2xl font-bold uppercase leading-tight tracking-wide text-white"></h2>
    </div>
  </header>

  <!-- Cuerpo (scrolleable) -->
  <div class="max-h-[calc(90vh-104px)] divide-y divide-line overflow-y-auto px-6">
    <!-- Resumen claro -->
    <p id="tm-intro" class="py-4 font-sans text-sm leading-relaxed text-ink"></p>

    <!-- Récord de la temporada -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">Récord de la temporada</h3>
      <div class="mt-3 flex items-end justify-between">
        <p>
          <span id="tm-wins" class="font-display text-3xl leading-none text-positive tabular"></span>
          <span class="ml-1 font-sans text-sm text-muted">ganados</span>
        </p>
        <p class="text-right">
          <span id="tm-losses" class="font-display text-3xl leading-none text-ink tabular"></span>
          <span class="ml-1 font-sans text-sm text-muted">perdidos</span>
        </p>
      </div>
      <div class="mt-2 h-2.5 overflow-hidden rounded-full bg-line">
        <div id="tm-bar" class="h-full rounded-full bg-positive" style="width:0%"></div>
      </div>
      <p id="tm-season-caption" class="mt-2 font-sans text-xs text-muted"></p>
    </section>

    <!-- Grupos de stats -->
    {GROUPS.map((group) => (
      <section class="py-5">
        <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">{group.title}</h3>
        <dl class="mt-3 flex flex-col gap-2.5">
          {group.rows.map((row) => (
            <div class="flex items-baseline justify-between gap-3">
              <dt class="font-sans text-sm text-muted">
                {row.tip ? (
                  <span data-tip={row.tip} tabindex="0" class={labelClass}>{row.label}</span>
                ) : (
                  row.label
                )}
              </dt>
              <dd id={row.id} class="font-sans text-sm font-semibold text-ink tabular"></dd>
            </div>
          ))}
        </dl>
      </section>
    ))}

    <!-- Forma reciente -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">Forma reciente</h3>
      <dl class="mt-3 flex flex-col gap-2.5">
        <div class="flex items-baseline justify-between gap-3">
          <dt class="font-sans text-sm text-muted">Últimos 10 juegos</dt>
          <dd id="tm-lastten" class="font-sans text-sm font-semibold text-ink tabular"></dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-sans text-sm text-muted">Racha actual</dt>
          <dd class="flex items-center gap-2">
            <span id="tm-streak"></span>
            <span id="tm-streak-text" class="font-sans text-xs text-muted"></span>
          </dd>
        </div>
      </dl>
    </section>

    <!-- Por situación -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">Cómo le va según la situación</h3>
      <p class="mt-1 font-sans text-xs text-muted">Récord y porcentaje de victorias en cada caso.</p>
      <dl id="tm-splits" class="mt-3 grid grid-cols-1 gap-x-8 gap-y-2.5 sm:grid-cols-2"></dl>
    </section>
  </div>
</dialog>

<style>
  #team-modal[open] {
    animation: modal-in 0.18s ease-out;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    #team-modal[open] { animation: none; }
  }
</style>

<script>
  import { initTeamModal } from "@/scripts/team-modal";
  import { initTooltips } from "@/scripts/tooltips";
  initTeamModal();
  initTooltips();
</script>
