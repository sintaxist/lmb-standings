---
import type { TeamDetailMap } from "@/lib/mlb";

interface Props {
  details: TeamDetailMap;
}

const { details } = Astro.props;

// Filas de la sección "En números": etiqueta + id del valor a rellenar.
const NUMBER_ROWS = [
  { id: "tm-league-rank", label: "Posición en la liga" },
  { id: "tm-div-record", label: "Récord en su división" },
  { id: "tm-rpg", label: "Carreras por juego" },
  { id: "tm-dif", label: "Diferencia de carreras" },
  { id: "tm-expected", label: "Récord esperado" },
  { id: "tm-magic", label: "Número mágico" },
] as const;
---

<!-- Detalle por equipo, consumido por el controlador del modal en cliente -->
<script id="team-details" type="application/json" set:html={JSON.stringify(details)}></script>

<dialog
  id="team-modal"
  class="m-auto max-h-[90vh] w-[min(94vw,560px)] overflow-hidden rounded-2xl border border-line bg-surface p-0 shadow-2xl backdrop:bg-black/55 backdrop:backdrop-blur-sm"
  aria-labelledby="tm-name"
>
  <!-- Cabecera oscura -->
  <header class="relative flex items-center gap-4 bg-ink px-6 pb-5 pt-6">
    <button
      id="tm-close"
      type="button"
      class="absolute right-4 top-4 flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-white/80 transition-colors hover:bg-white/20"
      aria-label="Cerrar"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <span id="tm-logo" class="inline-flex h-16 w-16 flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-white ring-2 ring-white/15"></span>

    <div class="min-w-0">
      <p id="tm-sub" class="font-sans text-xs font-semibold uppercase tracking-[0.16em] text-white/55"></p>
      <h2 id="tm-name" class="truncate font-display text-2xl font-bold uppercase leading-tight tracking-wide text-white"></h2>
    </div>
  </header>

  <!-- Cuerpo (scrolleable) -->
  <div class="max-h-[calc(90vh-104px)] divide-y divide-line overflow-y-auto px-6">
    <!-- Resumen en lenguaje claro -->
    <p id="tm-intro" class="py-5 font-sans text-sm leading-relaxed text-ink"></p>

    <!-- Su temporada -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">Su temporada</h3>
      <div class="mt-3 flex items-end justify-between">
        <p>
          <span id="tm-wins" class="font-display text-3xl leading-none text-positive tabular"></span>
          <span class="ml-1 font-sans text-sm text-muted">ganados</span>
        </p>
        <p class="text-right">
          <span id="tm-losses" class="font-display text-3xl leading-none text-ink tabular"></span>
          <span class="ml-1 font-sans text-sm text-muted">perdidos</span>
        </p>
      </div>
      <div class="mt-2 h-2.5 overflow-hidden rounded-full bg-line">
        <div id="tm-bar" class="h-full rounded-full bg-positive" style="width:0%"></div>
      </div>
      <p id="tm-season-caption" class="mt-2 font-sans text-xs text-muted"></p>
    </section>

    <!-- En números -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">En números</h3>
      <dl class="mt-3 grid grid-cols-1 gap-x-8 gap-y-2.5 sm:grid-cols-2">
        {NUMBER_ROWS.map((row) => (
          <div class="flex items-baseline justify-between gap-3">
            <dt class="font-sans text-sm text-muted">{row.label}</dt>
            <dd id={row.id} class="font-sans text-sm font-semibold text-ink tabular"></dd>
          </div>
        ))}
      </dl>
      <p class="mt-3 font-sans text-[11px] leading-relaxed text-muted/80">
        <strong class="font-semibold">Récord esperado:</strong> el que “debería” tener según las carreras a favor y en contra.
        <strong class="font-semibold">Número mágico:</strong> victorias que le faltan para asegurar su división.
      </p>
    </section>

    <!-- Forma reciente -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">Forma reciente</h3>
      <div class="mt-3 flex flex-wrap items-center gap-x-6 gap-y-2">
        <p class="font-sans text-sm text-ink">
          Últimos 10 juegos:
          <span id="tm-lastten" class="font-semibold tabular"></span>
        </p>
        <p class="flex items-center gap-2 font-sans text-sm text-ink">
          <span id="tm-streak"></span>
          <span id="tm-streak-text" class="text-muted"></span>
        </p>
      </div>
    </section>

    <!-- Por situación -->
    <section class="py-5">
      <h3 class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-muted">Cómo le va según la situación</h3>
      <p class="mt-1 font-sans text-xs text-muted">Récord y porcentaje de victorias en cada caso.</p>
      <dl id="tm-splits" class="mt-3 grid grid-cols-1 gap-x-8 gap-y-2.5 sm:grid-cols-2"></dl>
    </section>
  </div>
</dialog>

<style>
  #team-modal[open] {
    animation: modal-in 0.18s ease-out;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    #team-modal[open] { animation: none; }
  }
</style>

<script>
  import { initTeamModal } from "@/scripts/team-modal";
  initTeamModal();
</script>
